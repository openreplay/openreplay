# Minimal ingest stack — example env values (LOCAL TEST ONLY, not secrets).
#
# The worker env files under docker-envs/*.env contain ${COMMON_*} placeholders
# that must be expanded with envsubst before `docker compose up`, exactly as the
# full-stack install.sh does. run-minimal.sh below automates the whole flow.
#
# Copy to minimal.common.env and adjust if a port is taken:
#   cp minimal.common.env.example minimal.common.env

# Protocol: http because the minimal stack has no nginx/caddy TLS terminator.
COMMON_PROTOCOL=http
COMMON_DOMAIN_NAME=localhost

# Image tags (kept in sync with the tracked common.env).
POSTGRES_VERSION=17
CLICKHOUSE_VERSION=26.2-alpine
REDIS_VERSION=8
MINIO_VERSION=1.0.0-beta.1
HTTP_VERSION=v1.27.1
ENDER_VERSION=v1.27.4
SINK_VERSION=v1.27.2
STORAGE_VERSION=v1.27.0
DB_VERSION=v1.27.3
ASSETS_VERSION=v1.27.2

# Host ports (override to avoid collisions with a full stack on the same host).
HTTP_PORT=8090
MINIO_CONSOLE_PORT=9011

# Test credentials — replace for anything beyond a throwaway local run.
COMMON_S3_KEY=test_s3_key
COMMON_S3_SECRET=test_s3_secret
COMMON_PG_PASSWORD=test_pg_password
